@page
@{
    ViewData["Title"] = "CV";
}

<section class="page-hero">
    <div class="section-heading">
        <p data-i18n-en="CV" data-i18n-vi="CV">CV</p>
        <h2 data-i18n-en="A focused page for experience, skills, education, and the practical facts behind your portfolio." data-i18n-vi="Trang tap trung vao kinh nghiem, ky nang, hoc van va nhung thong tin thuc te dang sau portfolio cua ban.">A focused page for experience, skills, education, and the practical facts behind your portfolio.</h2>
    </div>
    <p class="page-lead" data-i18n-en="This page is structured like a modern online CV. Replace the sample content with your real timeline and qualifications." data-i18n-vi="Trang nay duoc cau truc nhu mot CV online hien dai. Hay thay noi dung mau bang moc thoi gian va nang luc thuc te cua ban.">This page is structured like a modern online CV. Replace the sample content with your real timeline and qualifications.</p>
</section>

<section class="section-shell cv-shell">
    <div class="cv-column">
        <div class="cv-card">
            <p class="cv-label" data-i18n-en="Core skills" data-i18n-vi="Ky nang cot loi">Core skills</p>
            <h3 data-i18n-en="Technical strengths" data-i18n-vi="Diem manh ky thuat">Technical strengths</h3>
            <ul>
                <li data-i18n-en="ASP.NET Core and Razor Pages" data-i18n-vi="ASP.NET Core va Razor Pages">ASP.NET Core and Razor Pages</li>
                <li data-i18n-en="HTML, CSS, JavaScript, and responsive UI" data-i18n-vi="HTML, CSS, JavaScript va giao dien responsive">HTML, CSS, JavaScript, and responsive UI</li>
                <li data-i18n-en="Frontend architecture and component systems" data-i18n-vi="Kien truc frontend va he thong component">Frontend architecture and component systems</li>
                <li data-i18n-en="Product websites, dashboards, and portfolio builds" data-i18n-vi="Website san pham, dashboard va portfolio">Product websites, dashboards, and portfolio builds</li>
            </ul>
        </div>

        <div class="cv-card">
            <p class="cv-label" data-i18n-en="Education" data-i18n-vi="Hoc van">Education</p>
            <h3 data-i18n-en="Your degree or training" data-i18n-vi="Bang cap hoac qua trinh dao tao">Your degree or training</h3>
            <p data-i18n-en="Add your school, program, graduation date, or relevant certifications here." data-i18n-vi="Them truong hoc, chuong trinh, nam tot nghiep hoac cac chung chi lien quan cua ban tai day.">Add your school, program, graduation date, or relevant certifications here.</p>
        </div>
    </div>

    <div class="cv-column">
        <div class="cv-card">
            <p class="cv-label" data-i18n-en="Experience" data-i18n-vi="Kinh nghiem">Experience</p>
            <h3 data-i18n-en="Your timeline" data-i18n-vi="Hanh trinh cua ban">Your timeline</h3>
            <div class="timeline-list">
                <article>
                    <strong data-i18n-en="Role Title" data-i18n-vi="Ten vi tri">Role Title</strong>
                    <span data-i18n-en="Company or freelance · Year to Year" data-i18n-vi="Cong ty hoac freelance · Nam den nam">Company or freelance · Year to Year</span>
                    <p data-i18n-en="Describe responsibilities, product context, and outcomes." data-i18n-vi="Mo ta trach nhiem, boi canh san pham va ket qua dat duoc.">Describe responsibilities, product context, and outcomes.</p>
                </article>
                <article>
                    <strong data-i18n-en="Role Title" data-i18n-vi="Ten vi tri">Role Title</strong>
                    <span data-i18n-en="Company or freelance · Year to Year" data-i18n-vi="Cong ty hoac freelance · Nam den nam">Company or freelance · Year to Year</span>
                    <p data-i18n-en="Describe the type of work, tools used, and the value you delivered." data-i18n-vi="Mo ta loai cong viec, cong cu su dung va gia tri ma ban mang lai.">Describe the type of work, tools used, and the value you delivered.</p>
                </article>
                <article>
                    <strong data-i18n-en="Role Title" data-i18n-vi="Ten vi tri">Role Title</strong>
                    <span data-i18n-en="Company or freelance · Year to Year" data-i18n-vi="Cong ty hoac freelance · Nam den nam">Company or freelance · Year to Year</span>
                    <p data-i18n-en="Use this slot for earlier work, internships, or a major independent project." data-i18n-vi="Su dung muc nay cho cong viec truoc day, thuc tap hoac mot du an ca nhan lon.">Use this slot for earlier work, internships, or a major independent project.</p>
                </article>
            </div>
        </div>
    </div>
</section>
