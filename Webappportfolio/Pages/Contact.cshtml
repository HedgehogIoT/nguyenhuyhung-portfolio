@page
@{
    ViewData["Title"] = "Contact Me";
}

<section class="page-hero">
    <div class="section-heading">
        <p data-i18n-en="Contact me" data-i18n-vi="Lien he">Contact me</p>
        <h2 data-i18n-en="Give visitors a direct way to reach you for freelance work, full-time roles, or project collaboration." data-i18n-vi="Cho nguoi xem mot cach truc tiep de lien he voi ban cho freelance, cong viec full-time hoac hop tac du an.">Give visitors a direct way to reach you for freelance work, full-time roles, or project collaboration.</h2>
    </div>
    <p class="page-lead" data-i18n-en="Replace the placeholders below with your actual email, phone, LinkedIn, GitHub, or booking link." data-i18n-vi="Hay thay cac thong tin mau ben duoi bang email, so dien thoai, LinkedIn, GitHub hoac link dat lich thuc te cua ban.">Replace the placeholders below with your actual email, phone, LinkedIn, GitHub, or booking link.</p>
</section>

<section class="section-shell contact-page-shell">
    <div class="contact-panel contact-panel-stacked">
        <div>
            <h3 data-i18n-en="Contact details" data-i18n-vi="Thong tin lien he">Contact details</h3>
            <p data-i18n-en="Use a simple, low-friction contact setup so people know exactly how to start the conversation." data-i18n-vi="Su dung cach lien he don gian, it ma sat de moi nguoi biet chinh xac phai bat dau cuoc tro chuyen tu dau.">Use a simple, low-friction contact setup so people know exactly how to start the conversation.</p>
        </div>
        <div class="contact-list">
            <a class="contact-item" href="mailto:hello@example.com">
                <span data-i18n-en="Email" data-i18n-vi="Email">Email</span>
                <strong>hello@example.com</strong>
            </a>
            <a class="contact-item" href="https://www.linkedin.com/" target="_blank" rel="noreferrer">
                <span>LinkedIn</span>
                <strong>linkedin.com/in/your-profile</strong>
            </a>
            <a class="contact-item" href="https://github.com/" target="_blank" rel="noreferrer">
                <span>GitHub</span>
                <strong>github.com/your-profile</strong>
            </a>
        </div>
    </div>
</section>
